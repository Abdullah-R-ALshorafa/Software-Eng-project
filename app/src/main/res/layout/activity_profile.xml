<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/main"
    tools:context=".profile">

    <LinearLayout
        android:id="@+id/Linear"
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:background="#03A9F4"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profile"
            android:textColor="@color/white"
            android:textSize="20sp" />
    </LinearLayout>

    <ImageView
        android:id="@+id/Iv_profile"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_margin="20dp"
        android:src="@drawable/person_black"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/Linear" />

    <TextView
        android:id="@+id/Tv_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:text="name"
        android:textSize="20sp"
        app:layout_constraintBottom_toBottomOf="@id/Iv_profile"
        app:layout_constraintStart_toEndOf="@id/Iv_profile"
        app:layout_constraintTop_toTopOf="@id/Iv_profile" />

    <TextView
        android:id="@+id/Tv_password"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="******@gmail.com"
        app:layout_constraintStart_toStartOf="@id/Tv_name"
        app:layout_constraintTop_toBottomOf="@id/Tv_name" />

    <TextView
        android:id="@+id/Tv_Account_type"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Admin"
        app:layout_constraintStart_toStartOf="@id/Tv_password"
        app:layout_constraintTop_toBottomOf="@id/Tv_password" />

    <LinearLayout
        android:id="@+id/Linear_EditUser"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_marginTop="50dp"
        android:background="#03A9F4"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/Iv_profile">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="15dp"
            android:text="Edit user"
            android:textColor="@color/white"
            android:textSize="20sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="15dp"
            android:text="You can you can edit your profile"
            android:textColor="#E4E4E4"
            android:textSize="17sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/Linear_AddProduct"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_marginTop="24dp"
        android:background="#03A9F4"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/Linear_editproduct">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="15dp"
            android:text="Add Product"
            android:textColor="@color/white"
            android:textSize="20sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="15dp"
            android:text="You can add a product if you are an admin"
            android:textColor="#E4E4E4"
            android:textSize="17sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/Linear_editproduct"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_marginTop="24dp"
        android:background="#03A9F4"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/Linear_EditUser">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="15dp"
            android:text="Edit product"
            android:textColor="@color/white"
            android:textSize="20sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="15dp"
            android:text="You can edit a product if you are an admin"
            android:textColor="#E4E4E4"
            android:textSize="17sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/Linear_home"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:background="#03A9F4"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/Iv_homeProfile"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="50dp"
            android:src="@drawable/baseline_home_24" />

        <ImageView
            android:id="@+id/Iv_cartProfile"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="100dp"
            android:src="@drawable/white_cart" />

        <ImageView
            android:id="@+id/Iv_profileProfile"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="100dp"
            android:background="@drawable/radus"
            android:backgroundTint="#9E9E9E"
            android:src="@drawable/white_person" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>